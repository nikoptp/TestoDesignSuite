{
  "name": "testo-design-suite",
  "productName": "testo-design-suite",
  "version": "0.1.0",
  "description": "My Electron application description",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "installer:custom": "node scripts/build-custom-installer.js",
    "build:windows:custom-installer": "npm run package && npm run installer:custom",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "build:test": "tsc -p tsconfig.test.json",
    "test:contracts": "npm run build:test && node test/run-tests.js",
    "test:unit": "vitest run --config vitest.config.mjs",
    "test": "npm run test:contracts && npm run test:unit"
  },
  "keywords": [],
  "author": {
    "name": "Niko Parviainen",
    "email": "joku.parviainen@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nikoptp/TestoDesignSuite.git"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@electron-forge/cli": "^7.6.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "css-loader": "^6.11.0",
    "electron": "40.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "jsdom": "^28.1.0",
    "node-loader": "^2.1.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.4",
    "typescript": "~4.5.4",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "electron-squirrel-startup": "^1.0.1",
    "motion": "^12.34.0",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "update-electron-app": "^3.1.2"
  }
}
